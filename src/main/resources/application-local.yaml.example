# 可选：复制为 application-local.yaml 覆盖下方配置
exchange:
  recommend:
    llm:
      provider: gemini
      api-key: your-gemini-api-key
      base-url: https://generativelanguage.googleapis.com
      model: gemini-2.0-flash

