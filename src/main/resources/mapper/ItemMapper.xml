<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.exchange.mapper.ItemMapper">

    <resultMap id="ItemResultMap" type="com.exchange.entity.Item">
        <id property="itemId" column="item_id"/>
        <result property="userId" column="user_id"/>
        <result property="categoryId" column="category_id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="exchangeWish" column="exchange_wish"/>
        <result property="images" column="images"/>
        <result property="status" column="status"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="itemQueryCondition">
        WHERE status = 1
        <if test="categoryId != null">
            AND category_id = #{categoryId}
        </if>
        <if test="keyword != null and keyword != ''">
            AND title LIKE CONCAT('%', #{keyword}, '%')
        </if>
    </sql>

    <select id="selectItemPage" resultMap="ItemResultMap">
        SELECT * FROM busi_item
        <include refid="itemQueryCondition"/>
        ORDER BY update_time DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="selectItemCount" resultType="int">
        SELECT COUNT(*) FROM busi_item
        <include refid="itemQueryCondition"/>
    </select>

</mapper>